# PulsarAI — copy to .env and fill in values (never commit .env)

# Environment: development | staging | production
ENVIRONMENT=development
PAPER_TRADING=true

# --- Ports (host machine — unusual ports to avoid conflicts) ---
API_PORT=18888
POSTGRES_PORT=15432
REDIS_PORT=16379
GRAFANA_PORT=13000
PROMETHEUS_PORT=19090

# --- Binance (TRADE ONLY — NO WITHDRAWAL) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

# --- Database (use host ports when running app on laptop outside Docker) ---
DATABASE_URL=postgresql://pulsarai:pulsarai_dev@localhost:15432/pulsarai
REDIS_URL=redis://localhost:16379/0

# Inside Docker Compose, these are overridden to service hostnames:
# DATABASE_URL=postgresql://pulsarai:pulsarai_dev@timescaledb:5432/pulsarai
# REDIS_URL=redis://redis:6379/0

POSTGRES_USER=pulsarai
POSTGRES_PASSWORD=pulsarai_dev
POSTGRES_DB=pulsarai

# --- Telegram (@BotFather) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_COMMANDS_ENABLED=false

# --- Monitoring (Phase 5) ---
METRICS_INTERVAL_SECONDS=60
DRIFT_CHECK_INTERVAL_HOURS=6
DAILY_SUMMARY_HOUR_UTC=0

# --- Risk limits ---
MAX_POSITION_RISK_PCT=0.02
MAX_OPEN_POSITIONS=5
MAX_SINGLE_ASSET_PCT=0.20
MAX_DAILY_DRAWDOWN_PCT=0.05
MAX_WEEKLY_DRAWDOWN_PCT=0.10
USDT_RESERVE_PCT=0.20
MIN_TRADE_SIZE_USDT=50

# --- Trading ---
INITIAL_BUDGET_USDT=1000

# --- Data ingestion ---
INGESTION_ENABLED=true
TRADING_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT
WS_KLINE_INTERVALS=1m,1h
HISTORICAL_INTERVALS=1h,4h,1d
HISTORICAL_DAYS=90
TOP_PAIRS_COUNT=10
BINANCE_REST_DELAY_SECONDS=0.2

# --- Optional APIs (Phase 3+) ---
CRYPTOPANIC_API_KEY=
GLASSNODE_API_KEY=

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me
